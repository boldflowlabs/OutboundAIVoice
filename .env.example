OUTBOUND_TRUNK_ID_UK=ST_xxxxxxxxxxxxxxxx
OUTBOUND_TRUNK_ID_CA=ST_xxxxxxxxxxxxxxxx
OUTBOUND_TRUNK_ID_AU=ST_xxxxxxxxxxxxxxxx
OUTBOUND_TRUNK_ID_AE=ST_xxxxxxxxxxxxxxxx

# ── Default Transfer Fallback ──
DEFAULT_TRANSFER_NUMBER=+15555550199

# ── Supabase ──
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── S3 Storage (Optional, for call recordings) ──
S3_ACCESS_KEY_ID=
