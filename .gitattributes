# Normalize all text files to LF on commit
* text=auto eol=lf

# Shell scripts must always use LF (Linux containers)
*.sh text eol=lf

# Windows-only files can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
