# BoldFlow Dashboard — Environment Variables
# Copy to .env and fill in your values

# Base URL of your FastAPI server (server.py)
VITE_API_URL=https://api.boldflow.in

# Supabase project credentials (from Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase Admin user email (used to detect admin role in authStore)
VITE_ADMIN_EMAIL=godson@boldflow.in
